generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Port {
  id             String  @id @default(cuid())
  portName       String
  locode         String  @unique
  latitude       Float
  longitude      Float
  timezoneOlson  String?
  countryIso     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

